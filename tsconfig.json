{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "noEmit": true,
    "paths": {
      "@super-calendar/core": ["./packages/core/src/index.ts"],
      "@super-calendar/native": ["./packages/native/src/index.tsx"],
      "@super-calendar/native/picker": ["./packages/native/src/picker.tsx"],
      "@super-calendar/dom": ["./packages/dom/src/index.ts"]
    }
  },
  "include": ["packages/*/src"],
  "exclude": ["**/dist", "**/node_modules"]
}
