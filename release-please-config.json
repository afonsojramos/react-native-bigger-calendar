{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "separate-pull-requests": false,
  "pull-request-title-pattern": "chore: release `@super-calendar`",
  "plugins": [
    "node-workspace",
    {
      "type": "linked-versions",
      "groupName": "super-calendar",
      "components": ["@super-calendar/core", "@super-calendar/native", "@super-calendar/dom"]
    }
  ],
  "packages": {
    "packages/core": {
      "extra-files": [{ "type": "json", "path": "packages/core/jsr.json", "jsonpath": "$.version" }]
    },
    "packages/native": {
      "extra-files": [
        { "type": "json", "path": "packages/native/jsr.json", "jsonpath": "$.version" }
      ]
    },
    "packages/dom": {
      "extra-files": [{ "type": "json", "path": "packages/dom/jsr.json", "jsonpath": "$.version" }]
    }
  }
}
